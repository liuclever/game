echo ========================================
echo.

echo [1/1] 初始化擂台表...
mysql -u root -p123456 game_tower < ../sql/012_arena_tables.sql
if %errorlevel% neq 0 (
    echo ❌ 擂台表初始化失败！
    pause
    exit /b 1
)

echo.
