echo 地阶擂台（40-49级）- 普通场/黄金场
echo 天阶擂台（50-59级）- 普通场/黄金场
echo 飞马擂台（60-69级）- 普通场/黄金场
echo 天龙擂台（70-79级）- 普通场/黄金场
echo 战神擂台（80-100级）- 普通场/黄金场
echo.
